<launch>
    <!-- Environment variables for simulation -->
    <env name="OM_DOCKING_DISTANCE" value="1.0"/>
    <env name="OM_UNDOCK_DISTANCE" value="1.0"/>
    <env name="OM_TOOL_WIDTH" value="0.14"/>
    <env name="OM_ENABLE_MOWER" value="false"/>
    <env name="OM_BATTERY_EMPTY_VOLTAGE" value="20.0"/>
    <env name="OM_OUTLINE_COUNT" value="4"/>
    <env name="OM_OUTLINE_OFFSET" value="0.05"/>
    <env name="OM_BATTERY_FULL_VOLTAGE" value="28.0"/>
    <env name="OM_MOWING_MOTOR_TEMP_HIGH" value="80.0"/>
    <env name="OM_MOWING_MOTOR_TEMP_LOW" value="40.0"/>
    <env name="OM_MQTT_ENABLE" value="False"/>
    <env name="OM_MOWER_GAMEPAD" value=""/>

    <!-- Mobile robot simulator (odometry + tf) -->
    <node pkg="mobile_robot_simulator" type="mobile_robot_simulator_node"
          name="mobile_robot_simulator" output="log">
        <param name="publish_map_transform" value="true"/>
        <param name="publish_rate" value="10.0"/>
        <param name="velocity_topic" value="/cmd_vel"/>
        <param name="odometry_topic" value="/mower/odom"/>
    </node>

    <!-- Mower simulation (fake hardware: status, IMU, GPS, etc.) -->
    <node pkg="mower_simulation" type="mower_simulation" name="mower_simulation" output="log"/>

    <!-- Map service -->
    <node pkg="mower_map" type="mower_map_service" name="mower_map" output="log"/>

    <!-- Coverage path planner -->
    <node pkg="slic3r_coverage_planner" type="slic3r_coverage_planner"
          name="slic3r_coverage_planner" output="log"/>

    <!-- Navigation stack (move_base_flex) -->
    <include file="$(find open_mower)/launch/include/_move_base.launch"/>

    <!-- Mower logic (state machine) -->
    <node pkg="mower_logic" type="mower_logic" name="mower_logic" output="screen">
        <param name="ignore_gps_errors" value="true"/>
        <param name="gps_wait_time" value="0"/>
        <param name="automatic_mode" value="0"/>
        <param name="docking_distance" value="1.0"/>
        <param name="undock_distance" value="1.0"/>
        <param name="tool_width" value="0.14"/>
        <param name="enable_mower" value="false"/>
        <param name="battery_empty_voltage" value="20.0"/>
        <param name="outline_count" value="4"/>
        <param name="outline_overlap_count" value="0"/>
        <param name="outline_offset" value="0.05"/>
        <param name="mow_angle_offset" value="0"/>
        <param name="mow_angle_offset_is_absolute" value="false"/>
        <param name="mow_angle_increment" value="0"/>
        <param name="battery_full_voltage" value="28.0"/>
        <param name="motor_hot_temperature" value="80.0"/>
        <param name="motor_cold_temperature" value="40.0"/>
    </node>

    <!-- twist_mux for velocity arbitration -->
    <node pkg="twist_mux" type="twist_mux" name="twist_mux" output="log">
        <remap from="cmd_vel_out" to="/cmd_vel"/>
        <rosparam file="$(find open_mower)/params/twist_mux_topics.yaml" command="load"/>
    </node>

    <!-- The test node -->
    <test test-name="test_sim_startup" pkg="mower_logic" type="test_sim_startup.py" time-limit="120.0"/>
</launch>
