# open_mower_ros image tag to test, e.g. a released version tag such as v1.2.3, "edge"
# (latest main), or a PR/sha tag from ghcr.io/clemenselflein/open_mower_ros. Only used
# for the default BASE_IMAGE below - irrelevant if you set BASE_IMAGE explicitly.
VERSION=edge

# Which open_mower_ros image open_mower_ros and mower_simulation_gui are both built
# from/run. Defaults to the published tag above. To test local, uncommitted source
# changes instead, first build it once:
#   docker compose --profile build-from-source build build_from_source
# then uncomment the next line:
# BASE_IMAGE=local/open_mower_ros:local

# OpenMowerApp image tag to test.
# This is the older "blue" Flutter one
LEGACY_APP_VERSION=latest

# openmower-app image tag to test.
# This is the newer one with the map editor (green style)
APP_VERSION=edge

# Which hardware profile to load params for. CUSTOM (default) loads
# data/params/custom_params.yaml directly - that's what's seeded in this repo, already
# configured for the simulator (see its comments). Switching to a predefined profile
# (e.g. YardForce500) instead requires a data/params/mower_params.yaml override file,
# which isn't shipped here.
MOWER=CUSTOM

# Optional: host ports the simulation GUI is published on. NOVNC_PORT is the browser
# URL (http://<host>:6080), VNC_PORT is for native VNC clients if you prefer one. Change
# these if something else on your host already uses 6080/5900.
NOVNC_PORT=6080
VNC_PORT=5900

# Optional: virtual display resolution for the simulation GUI.
DISPLAY_RESOLUTION=1920x1080x24

# Anything else you add here is passed straight through to open_mower_ros (env_file),
# same as a real deployment - e.g. enable full debug logging:
DEBUG=True
